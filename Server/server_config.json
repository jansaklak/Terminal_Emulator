{
    "HOST": "0.0.0.0",
    "PORT": 51234,
    "LOG_DIR": "/var/log/terminal-server",
    "CONFIGS": {
        "Bazy1": {
            "session": {
                "mode": "mysql",
                "base_name": "mysql_lab",
                "image": "mysql:8.0",
                "network": "lab-net",
                "database": "labdb",
                "user": "labuser",
                "password": "labpass",
                "root_password": "rootpass",
                "seed_sql": "./Shared/Bazy/init.sql",
                "seed_target": "/docker-entrypoint-initdb.d/init.sql",
                "attach_command": [
                    "mysql",
                    "-h{service_container}",
                    "-ulabuser",
                    "-plabpass",
                    "labdb"
                ]
            },
            "cpu_limit": "0.5",
            "mem_limit": "256m",
            "description": "MySQL labdb (użytkownik labuser)"
        },
        "LinuxTerminal": {
            "session": {
                "mode": "container",
                "base_name": "ubuntu_shell",
                "image": "ubuntu:22.04",
                "seed_dir": "./Shared/Ubuntu",
                "mount_path": "/shared_data",
                "workdir": "/shared_data",
                "hostname_template": "{user}-lab",
                "service_command": [
                    "sleep",
                    "infinity"
                ],
                "attach_command": [
                    "/bin/bash"
                ]
            },
            "cpu_limit": "0.5",
            "mem_limit": "256m",
            "description": "Powłoka bash (Ubuntu)"
        },
        "BazyRoot": {
            "session": {
                "mode": "mysql",
                "base_name": "mysql_lab",
                "image": "mysql:8.0",
                "network": "lab-net",
                "database": "labdb",
                "user": "labuser",
                "password": "labpass",
                "root_password": "rootpass",
                "seed_sql": "./Shared/Bazy/init.sql",
                "seed_target": "/docker-entrypoint-initdb.d/init.sql",
                "attach_command": [
                    "mysql",
                    "-h{service_container}",
                    "-uroot",
                    "-prootpass",
                    "labdb"
                ]
            },
            "cpu_limit": "1.0",
            "mem_limit": "512m",
            "description": "MySQL labdb (root)"
        }
    }
}